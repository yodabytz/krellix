{
  "name": "suede",
  "version": "1.0",
  "author": "GKrellM 'SuedE' theme (assets) — krellix project (mapping)",
  "description": "Port of the GKrellM 'SuedE' theme. Soft brown suede texture with green and steel-blue accents.",

  "colors": {
    "panel_bg":           "#5a4a3a",
    "panel_border":       "#3a2c20",
    "panel_highlight":    "#7a6a52",
    "chart_bg":           "#1a1410",
    "chart_grid":         "#3a2c20",
    "text_primary":       "#d4c8b8",
    "text_secondary":     "#9a8c78",
    "text_accent":        "#b8a48c",
    "krell_track":        "#3a2c20",
    "krell_indicator":    "#d4c8b8",
    "chart_line_default": "#2fa35f",
    "chart_line_cpu":     "#e85a4a",
    "chart_line_mem":     "#2fa35f",
    "chart_line_swap":    "#7590bd",
    "chart_line_net_rx":  "#7590bd",
    "chart_line_net_tx":  "#d4af37",
    "chart_line_disk":    "#a070c0",
    "accent_warning":     "#d4881c",
    "accent_critical":    "#e85a4a"
  },

  "fonts": {
    "label": { "family": "Helvetica", "size": 9,  "bold": false },
    "value": { "family": "Helvetica", "size": 10, "bold": true  },
    "time":  { "family": "Helvetica", "size": 11, "bold": false }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    1,
    "panel_border":     0,
    "panel_min_width":  150,
    "krell_height":     12,
    "chart_height":     33,
    "chart_grid_lines": 4
  },

  "images": {
    "panel_bg":     { "image": "bg_panel.png", "mode": "tile" },
    "chart_bg":     { "image": "bg_chart.png", "mode": "tile" },
    "krell":        { "image": "krell_meter.png", "frames": 1, "vertical": 0 },
    "frame_left":   "frame_left.png",
    "frame_right":  "frame_right.png"
  }
}
