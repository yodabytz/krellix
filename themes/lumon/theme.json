{
  "name": "lumon",
  "version": "1.7",
  "author": "krellix",
  "description": "Lumon — muted terminal with controlled blue hierarchy.",

  "colors": {
    "panel_bg":           "#1f3447",
    "panel_border":       "#2a445a",
    "panel_highlight":    "#263f55",

    "chart_bg":           "#1f3447",
    "chart_grid":         "#263f55",

    "text_primary":       "#7c96a8",
    "text_secondary":     "#5f7687",
    "text_accent":        "#8faec2",

    "krell_track":        "#263f55",
    "krell_indicator":    "#79a6b9",

    "chart_line_default": "#79a6b9",

    "chart_line_cpu":     "#8faec2",
    "chart_line_mem":     "#79a6b9",
    "chart_line_swap":    "#beb780",
    "chart_line_net_rx":  "#a6c0d0",
    "chart_line_net_tx":  "#79a6b9",
    "chart_line_disk":    "#3b556b",

    "accent_warning":     "#beb780",
    "accent_critical":    "#20464f"
  },

  "fonts": {
    "label": { "family": "Monospace", "size": 9,  "bold": false },
    "value": { "family": "Monospace", "size": 10, "bold": false }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    2,
    "panel_border":     1,
    "panel_min_width":  100,
    "krell_height":     8,
    "chart_height":     70,
    "chart_grid_lines": 4
  }
}
