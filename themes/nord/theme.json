    "text_primary":       "#d8dee9",
    "text_secondary":     "#81a1c1",
    "text_accent":        "#b48ead",
    "krell_track":        "#3b4252",
    "krell_indicator":    "#88c0d0",
    "chart_line_default": "#88c0d0",
    "chart_line_cpu":     "#bf616a",
    "chart_line_mem":     "#a3be8c",
    "chart_line_swap":    "#ebcb8b",
    "chart_line_net_rx":  "#8fbcbb",
