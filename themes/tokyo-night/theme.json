{
  "name": "tokyo-night",
  "version": "1.0",
  "author": "krellix",
  "description": "Tokyo Night — clean, balanced dark theme using official palette.",

  "colors": {
    "panel_bg":           "#1a1b26",
    "panel_border":       "#283457",
    "panel_highlight":    "#414868",

    "chart_bg":           "#1a1b26",
    "chart_grid":         "#414868",

    "text_primary":       "#c0caf5",
    "text_secondary":     "#a9b1d6",
    "text_accent":        "#bb9af7",

    "krell_track":        "#414868",
    "krell_indicator":    "#7aa2f7",

    "chart_line_default": "#7aa2f7",

    "chart_line_cpu":     "#f7768e",
    "chart_line_mem":     "#9ece6a",
    "chart_line_swap":    "#e0af68",
    "chart_line_net_rx":  "#7dcfff",
    "chart_line_net_tx":  "#bb9af7",
    "chart_line_disk":    "#a9b1d6",

    "accent_warning":     "#e0af68",
    "accent_critical":    "#f7768e"
  },

  "fonts": {
    "label": { "family": "Monospace", "size": 9,  "bold": false },
    "value": { "family": "Monospace", "size": 10, "bold": true  }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    2,
    "panel_border":     1,
    "panel_min_width":  100,
    "krell_height":     8,
    "chart_height":     70,
    "chart_grid_lines": 5
  }
}
