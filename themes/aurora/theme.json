{
  "name": "aurora",
  "version": "1.0",
  "author": "krellix",
  "description": "Aurora — luminous green, cyan, violet, and rose light bands over a deep polar-night base.",

  "comment_v2_demo":
    "Aurora is the reference theme for imageless v2 styling: monitor-specific panel gradients, bright krell sweeps, gradient charts, and soft text glow.",

  "surfaces": {
    "panel_bg":         { "slice": 0, "opacity": 1.0 },
    "panel_bg_host":    { "slice": 0, "opacity": 1.0 },
    "panel_bg_clock":   { "slice": 0, "opacity": 1.0 },
    "panel_bg_cpu":     { "slice": 0, "opacity": 1.0 },
    "panel_bg_mem":     { "slice": 0, "opacity": 1.0 },
    "panel_bg_net":     { "slice": 0, "opacity": 1.0 },
    "panel_bg_disk":    { "slice": 0, "opacity": 1.0 },
    "panel_bg_uptime":  { "slice": 0, "opacity": 1.0 },
    "panel_bg_battery": { "slice": 0, "opacity": 1.0 },
    "panel_bg_sensors": { "slice": 0, "opacity": 1.0 }
  },

  "comment_text_styles":
    "Subtle 1px shadow on the primary text gives it a soft glow without obscuring at small sizes. Accent text uses a slightly stronger shadow to pop against busy gradient backgrounds.",
  "text_styles": {
    "text_primary":   { "color": "#dce0ff", "shadow": { "x": 1, "y": 1, "color": "#0010204d" } },
    "text_secondary": { "color": "#8e9bbf" },
    "text_accent":    { "color": "#7df5ff", "shadow": { "x": 1, "y": 1, "color": "#001a2a99" } }
  },

  "comment_colors":
    "Panel gradients are intentionally bright enough to read as northern lights while keeping the base dark enough for dense monitor text.",
  "colors": {
    "panel_bg": {
      "gradient": "linear",
      "angle":    115,
      "stops":    [[0.0, "#05102a"], [0.34, "#0a3150"], [0.58, "#0a6a63"], [0.76, "#28316a"], [1.0, "#070b20"]]
    },
    "panel_bg_host": {
      "gradient": "linear",
      "angle":    105,
      "stops":    [[0.0, "#06112e"], [0.30, "#0d766d"], [0.58, "#47e89d"], [0.78, "#654dff"], [1.0, "#080b1d"]]
    },
    "panel_bg_clock": {
      "gradient": "linear",
      "angle":    100,
      "stops":    [[0.0, "#080c26"], [0.32, "#12357c"], [0.55, "#21d5dc"], [0.80, "#8f65ff"], [1.0, "#090a1c"]]
    },
    "panel_bg_cpu": {
      "gradient": "linear",
      "angle":    110,
      "stops":    [[0.0, "#061329"], [0.25, "#0b5066"], [0.48, "#35f4a1"], [0.70, "#20b8ff"], [1.0, "#090b1f"]]
    },
    "panel_bg_mem": {
      "gradient": "linear",
      "angle":    112,
      "stops":    [[0.0, "#081027"], [0.30, "#233a80"], [0.54, "#a56dff"], [0.72, "#35e9c4"], [1.0, "#090b1f"]]
    },
    "panel_bg_net": {
      "gradient": "linear",
      "angle":    108,
