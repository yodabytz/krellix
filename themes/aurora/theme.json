    "accent_warning":  "#ffe26a",
    "accent_critical": "#ff4f9f"
  },

  "fonts": {
    "label": { "family": "Monospace", "size": 9,  "bold": false },
    "value": { "family": "Monospace", "size": 10, "bold": true  },
    "time":  { "family": "Monospace", "size": 11, "bold": false }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    2,
    "panel_border":     1,
    "panel_min_width":  100,
    "krell_height":     11,
    "chart_height":     74,
    "chart_grid_lines": 4,
    "panel_bg_slice":   0
  }
}
