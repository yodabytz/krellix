{
  "name": "aliens",
  "version": "1.0",
  "author": "Alan Swanson (assets, ca. 2001) — krellix project (mapping)",
  "description": "Port of the classic GKrellM 'Aliens' theme. Sci-fi green-yellow on dark, with original tileable PNGs.",

  "colors": {
    "panel_bg":           "#1a1a14",
    "panel_border":       "#2a2820",
    "panel_highlight":    "#3a3828",
    "chart_bg":           "#0a0a0a",
    "chart_grid":         "#2a2820",
    "text_primary":       "#cdca94",
    "text_secondary":     "#8a8770",
    "text_accent":        "#e8e0a4",
    "krell_track":        "#1a1a14",
    "krell_indicator":    "#cdca94",
    "chart_line_default": "#cdca94",
    "chart_line_cpu":     "#ff6644",
    "chart_line_mem":     "#88dd44",
    "chart_line_swap":    "#ffaa44",
    "chart_line_net_rx":  "#44ddff",
    "chart_line_net_tx":  "#ddaa44",
    "chart_line_disk":    "#cc88ff",
    "accent_warning":     "#ff8844",
    "accent_critical":    "#ff4444"
  },

  "fonts": {
    "label": { "family": "Helvetica", "size": 8,  "bold": false },
    "value": { "family": "Helvetica", "size": 10, "bold": true  }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    0,
    "panel_border":     0,
    "panel_min_width":  170,
    "krell_height":     12,
    "chart_height":     33,
    "chart_grid_lines": 4
  },

  "images": {
    "panel_bg": "bg_panel.png",
    "chart_bg": "bg_chart.png",
    "krell":    { "image": "krell_panel.png", "frames": 4, "vertical": 1 }
  }
}
