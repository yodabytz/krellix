{
  "name": "gruvbox-dark",
  "version": "1.0",
  "author": "krellix",
  "description": "Gruvbox Dark — retro warm tones by Pavel Pertsev (vim).",

  "colors": {
    "panel_bg":        "#282828",
    "panel_border":    "#504945",
    "panel_highlight": "#3c3836",
    "chart_bg":        "#1d2021",
    "chart_grid":      "#504945",
    "text_primary":    "#ebdbb2",
    "text_secondary":  "#a89984",
    "krell_track":     "#3c3836",
    "krell_indicator": "#fabd2f"
  },

  "fonts": {
    "label": { "family": "Monospace", "size": 9,  "bold": false },
    "value": { "family": "Monospace", "size": 10, "bold": true  }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    2,
    "panel_border":     1,
    "panel_min_width":  200,
    "krell_height":     8,
    "chart_height":     32,
    "chart_grid_lines": 4
  }
}
