{
  "name": "default",
  "version": "1.0",
  "author": "krellix",
  "description": "Classic green-on-black, in the spirit of GKrellM.",

  "colors": {
    "panel_bg":        "#0a0e0a",
    "panel_border":    "#1a2a1a",
    "panel_highlight": "#284828",
    "chart_bg":        "#000000",
    "chart_grid":      "#0a3a0a",
    "text_primary":    "#7fff7f",
    "text_secondary":  "#3fbf3f",
    "krell_track":     "#1a3a1a",
