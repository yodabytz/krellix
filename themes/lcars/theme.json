{
  "name": "lcars",
  "version": "1.0",
  "author": "GKrellM 'gkLCARS' theme (assets) — krellix project (mapping)",
  "description": "Port of the gkLCARS GKrellM theme. Star Trek LCARS interface — orange, peach, and yellow on black.",

  "colors": {
    "panel_bg":           "#000000",
    "panel_border":       "#ffa500",
    "panel_highlight":    "#3a2810",
    "chart_bg":           "#000000",
    "chart_grid":         "#3a2810",
    "text_primary":       "#ffcc66",
    "text_secondary":     "#cc7a3a",
    "text_accent":        "#ff9966",
    "krell_track":        "#3a2810",
    "krell_indicator":    "#ffa500",
    "chart_line_default": "#ffa500",
    "chart_line_cpu":     "#ff6b35",
    "chart_line_mem":     "#adff2f",
    "chart_line_swap":    "#ffcc66",
    "chart_line_net_rx":  "#88ccff",
    "chart_line_net_tx":  "#f4a460",
    "chart_line_disk":    "#cc66ff",
    "accent_warning":     "#ffa500",
    "accent_critical":    "#ff3333"
  },

  "fonts": {
    "label": { "family": "Helvetica", "size": 9,  "bold": false },
    "value": { "family": "Helvetica", "size": 10, "bold": true  },
    "time":  { "family": "Helvetica", "size": 11, "bold": false }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    1,
    "panel_border":     0,
    "panel_min_width":  170,
    "krell_height":     12,
    "chart_height":     40,
    "chart_grid_lines": 4
  },

  "images": {
    "panel_bg":     { "image": "bg_panel.png", "mode": "tile" },
    "chart_bg":     { "image": "bg_chart.png", "mode": "tile" },
    "frame_top":    "frame_top.png",
    "frame_bottom": "frame_bottom.png",
    "frame_left":   "frame_left.png",
    "frame_right":  "frame_right.png"
  }
}
