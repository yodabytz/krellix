{
  "name": "lcars",
  "version": "1.2",
  "author": "krellix",
  "description": "Star Trek LCARS — canonical bright-orange/amber/peach/periwinkle on black, the look from the show.",

  "colors": {
    "panel_bg":           "#000000",
    "panel_border":       "#FF9900",
    "panel_highlight":    "#FFCC66",
    "chart_bg":           "#000000",
    "chart_grid":         "#552200",
    "text_primary":       "#FF9900",
    "text_secondary":     "#FFCC66",
    "text_accent":        "#FFAD8B",
    "krell_track":        "#3a1a00",
    "krell_indicator":    "#FF9900",
    "chart_line_default": "#FF9900",
    "chart_line_cpu":     "#FF6E33",
    "chart_line_mem":     "#99CCFF",
    "chart_line_swap":    "#FFCC66",
    "chart_line_net_rx":  "#99CCFF",
    "chart_line_net_tx":  "#FF9900",
    "chart_line_disk":    "#CC99FF",
    "accent_warning":     "#FFCC66",
    "accent_critical":    "#FF6E33"
  },

  "fonts": {
    "label": { "family": "Monospace", "size": 9,  "bold": false },
    "value": { "family": "Monospace", "size": 10, "bold": true  },
    "time":  { "family": "Monospace", "size": 11, "bold": false }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    1,
    "panel_border":     1,
    "panel_min_width":  100,
    "krell_height":     8,
    "chart_height":     32,
    "chart_grid_lines": 4
  }
}
