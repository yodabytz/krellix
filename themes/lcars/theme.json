{
  "name": "lcars",
  "version": "1.1",
  "author": "krellix",
  "description": "LCARS-inspired vivid palette — pulled from gklcars reference, the high-saturation colors (bright amber, periwinkle, yellow-green) on near-black.",

  "colors": {
    "panel_bg":           "#040203",
    "panel_border":       "#D89E32",
    "panel_highlight":    "#D4D049",
    "chart_bg":           "#0a0408",
    "chart_grid":         "#5a3010",
    "text_primary":       "#D4D049",
    "text_secondary":     "#948DDE",
    "text_accent":        "#D89E32",
    "krell_track":        "#3a2810",
    "krell_indicator":    "#D89E32",
    "chart_line_default": "#D89E32",
    "chart_line_cpu":     "#D4D049",
    "chart_line_mem":     "#948DDE",
    "chart_line_swap":    "#CD9951",
    "chart_line_net_rx":  "#7C7CCA",
    "chart_line_net_tx":  "#D89E32",
    "chart_line_disk":    "#CBDB98",
    "accent_warning":     "#D89E32",
    "accent_critical":    "#D4D049"
  },

  "fonts": {
    "label": { "family": "Monospace", "size": 9,  "bold": false },
    "value": { "family": "Monospace", "size": 10, "bold": true  },
    "time":  { "family": "Monospace", "size": 11, "bold": false }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    1,
    "panel_border":     1,
    "panel_min_width":  100,
    "krell_height":     8,
    "chart_height":     32,
    "chart_grid_lines": 4
  }
}
