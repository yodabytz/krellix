{
  "name": "cheese",
  "version": "1.0",
  "author": "Tom Fogg <skicker@iname.com> (assets) — krellix project (mapping)",
  "description": "Port of Tom Fogg's GKrellM 'Cheese' theme. Warm cheese-tan textures with brown trim.",

  "colors": {
    "panel_bg":           "#d4c87c",
    "panel_border":       "#7a6228",
    "panel_highlight":    "#e8dc90",
    "chart_bg":           "#2a2618",
    "chart_grid":         "#5a5038",
    "text_primary":       "#3a2818",
    "text_secondary":     "#6a5a3a",
    "text_accent":        "#7a4824",
    "krell_track":        "#a89668",
    "krell_indicator":    "#3a2818",
    "chart_line_default": "#b6b798",
    "chart_line_cpu":     "#c44833",
    "chart_line_mem":     "#6b8e23",
    "chart_line_swap":    "#d4af37",
    "chart_line_net_rx":  "#c8a850",
    "chart_line_net_tx":  "#c44833",
    "chart_line_disk":    "#8b6f3a",
    "accent_warning":     "#d4881c",
    "accent_critical":    "#c43820"
  },

  "fonts": {
    "label": { "family": "Helvetica", "size": 9,  "bold": false },
    "value": { "family": "Helvetica", "size": 10, "bold": true  },
    "time":  { "family": "Helvetica", "size": 11, "bold": false }
  },

  "metrics": {
    "panel_padding":    4,
    "panel_spacing":    1,
    "panel_border":     0,
    "panel_min_width":  170,
    "krell_height":     12,
    "chart_height":     40,
    "chart_grid_lines": 4
  },

  "images": {
    "panel_bg":     { "image": "bg_panel.png", "mode": "tile" },
    "chart_bg":     { "image": "bg_chart.png", "mode": "tile" },
    "frame_top":    "frame_top.png",
    "frame_bottom": "frame_bottom.png",
    "frame_left":   "frame_left.png",
    "frame_right":  "frame_right.png"
  }
}
