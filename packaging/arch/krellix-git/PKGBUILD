# Maintainer: yodabytz <yodabytz@gmail.com>

pkgbase=krellix-git
_pkgname=krellix
pkgname=('krellix-git' 'krellix-server-git')
pkgver=0.1.0.r0.g0000000
pkgrel=1
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base' 'git')
source=("$_pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
    cd "$_pkgname"
    git describe --long --tags 2>/dev/null \
        | sed 's/^v//;s/-/.r/;s/-/./' \
        || printf "0.0.0.r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "$_pkgname"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build
}

package_krellix-git() {
    pkgdesc='Themeable Qt 6 system monitor in the spirit of GKrellM (GUI client, git HEAD)'
    depends=('qt6-base')
    optdepends=('krellix-server-git: monitor remote hosts via krellix --host')
    provides=("$_pkgname=$pkgver")
    conflicts=("$_pkgname")

    cd "$_pkgname"
    DESTDIR="$pkgdir" cmake --install build
    rm -f "$pkgdir/usr/bin/krellixd"

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$_pkgname/README.md"
}

package_krellix-server-git() {
    pkgdesc='krellixd — remote monitoring daemon for krellix (git HEAD)'
    depends=('qt6-base')
    optdepends=('docker: friendly Docker bridge name resolution')
    provides=("krellix-server=$pkgver")
    conflicts=("krellix-server")
    backup=('etc/krellixd/krellixd.conf')

    cd "$_pkgname"

    install -Dm755 build/bin/krellixd "$pkgdir/usr/bin/krellixd"
    install -Dm644 packaging/systemd/krellixd.service \
        "$pkgdir/usr/lib/systemd/system/krellixd.service"
    install -Dm644 packaging/systemd/krellixd.service.d/bare-metal-hardening.conf \
        "$pkgdir/usr/share/doc/krellix-server/krellixd.service.d/bare-metal-hardening.conf"
    install -Dm644 packaging/systemd/krellixd.service.d/docker-aliases.conf \
        "$pkgdir/usr/share/doc/krellix-server/krellixd.service.d/docker-aliases.conf"

    install -dm755 "$pkgdir/etc/krellixd"
    cat > "$pkgdir/etc/krellixd/krellixd.conf" <<'CONF'
[server]
listen=127.0.0.1
port=19150
update_hz=1
max_clients=4
io_timeout=300

[security]
allow_hosts=
CONF

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/krellix-server/LICENSE"
}
